<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TransitOps Login</title>

    <link rel="stylesheet" href="login.css">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <script src="https://kit.fontawesome.com/4f7b9b6b0d.js" crossorigin="anonymous"></script>
</head>

<body>

<main class="container">

    <!-- LEFT PANEL -->

    <section class="left">

        <header class="brand">

            <span class="logo">
                <i class="fa-solid fa-truck-fast"></i>
            </span>

            <h1>TransitOps</h1>

            <p>Smart Transport Operations Platform</p>

        </header>


        <article class="hero">

            <h2>One Login,<br>Four Roles</h2>

            <p>
                Secure access for every department involved in transport
                management.
            </p>

        </article>


        <nav class="roles">

            <ul>

                <li>
                    <i class="fa-solid fa-circle-check"></i>
                    Fleet Manager
                </li>

                <li>
                    <i class="fa-solid fa-circle-check"></i>
                    Dispatcher
                </li>

                <li>
                    <i class="fa-solid fa-circle-check"></i>
                    Safety Officer
                </li>

                <li>
                    <i class="fa-solid fa-circle-check"></i>
                    Financial Analyst
                </li>

            </ul>

        </nav>


        <footer class="left-footer">

            <p>TransitOps © 2026</p>

            <small>Role Based Access Control Enabled</small>

        </footer>

    </section>



    <!-- RIGHT PANEL -->

    <section class="right">

        <form id="loginForm">

            <h2>Sign in to your account</h2>

            <p class="subtitle">
                Enter your credentials to continue
            </p>



            <!-- EMAIL -->

            <label>Email Address</label>

            <input
                type="email"
                id="email"
                placeholder="you@example.com"
            >



            <!-- PASSWORD -->

            <label>Password</label>

            <section class="password-box">

                <input
                    type="password"
                    id="password"
                    placeholder="••••••••"
                >

                <button
                    type="button"
                    id="togglePassword"
                    class="eye"
                >
                    <i class="fa-solid fa-eye"></i>
                </button>

            </section>



            <!-- ROLE -->

            <label>Select Role</label>

            <select id="role">

                <option value="">
                    Choose your role
                </option>

                <option>
                    Fleet Manager
                </option>

                <option>
                    Dispatcher
                </option>

                <option>
                    Safety Officer
                </option>

                <option>
                    Financial Analyst
                </option>

            </select>



            <!-- OPTIONS -->

            <section class="options">

                <label class="remember">

                    <input type="checkbox">

                    Remember me

                </label>

                <a href="#">
                    Forgot Password?
                </a>

            </section>



            <!-- LOGIN -->

            <button
                type="submit"
                class="login-btn"
            >
                Sign In
            </button>



            <!-- INFO -->

            <section class="access">

                <small>
                    Access is scoped by role after login.
                </small>

                <section class="badges">

                    <span>Fleet Manager</span>

                    <span>Dispatcher</span>

                    <span>Safety Officer</span>

                    <span>Financial Analyst</span>

                </section>

            </section>

        </form>

    </section>

</main>



<!-- POPUP -->

<dialog id="popup">

    <p id="popupMessage"></p>

    <button id="closePopup">
        OK
    </button>

</dialog>

<script src="auth.js"></script>

</body>
</html>
